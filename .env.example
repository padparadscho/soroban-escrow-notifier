# RPC URL (e.g., https://soroban-testnet.stellar.org)
SOROBAN_RPC_URL=
# Network Passphrase (e.g., "Test SDF Network ; September 2015")
NETWORK_PASSPHRASE=

# The escrow contract ID to listen to
SOROBAN_ESCROW_CONTRACT_ID=
# The SAC (Soroban Asset Contract) ID used in the escrow
STELLAR_ASSET_CONTRACT_ID=

# Explorer Configuration (e.g., https://stellar.expert/explorer/testnet)
STELLAR_EXPLORER_BASE_URL=

# PosgreSQL Database URL
DATABASE_URL=

# Polling interval in milliseconds
POLLING_INTERVAL=

# Platform toggles (true/false)
ENABLE_TWITTER=
ENABLE_DISCORD=
ENABLE_TELEGRAM=

# Dry run mode (true/false)
DRY_RUN=

# Twitter API (v2)
# API Key & Secret
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
# Access Token & Secret
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Discord Webhook
DISCORD_WEBHOOK_URL=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=